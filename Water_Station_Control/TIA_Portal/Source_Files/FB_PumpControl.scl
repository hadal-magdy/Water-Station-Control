// ====================================================
// FB_PumpControl
// التحكم في طلمبة واحدة - Manual و Auto
// بيتم استدعاؤه 5 مرات من الـ OB1 (واحدة لكل طلمبة)
// ====================================================

FUNCTION_BLOCK "FB_PumpControl"
{ S7_Optimized_Access := 'TRUE' }
AUTHOR : 'WaterStation'
VERSION : '1.0'

VAR_INPUT
    iPumpIndex      : INT;      // رقم الطلمبة (1-5)
    bMasterAuto     : BOOL;     // الوضع العام للسيستم
    bAutoRunCmd     : BOOL;     // أمر تشغيل من منطق الأوتوماتيك
    rAutoSpeed      : REAL;     // السرعة المطلوبة من الأوتوماتيك
    rManualSpeed    : REAL;     // السرعة الثابتة للـ Manual
    rRampRate       : REAL;     // معدل الـ Ramp %/ثانية
    bFaultReset     : BOOL;     // إعادة تصفير الفولت
END_VAR

VAR_OUTPUT
    bRunning        : BOOL;     // الطلمبة شغالة
    bFault          : BOOL;     // في فولت
    rActualSpeed    : REAL;     // السرعة الفعلية
END_VAR

VAR
    // edge detection
    bStart_R        : BOOL;
    bStart_Prev     : BOOL;
    bStop_R         : BOOL;
    bStop_Prev      : BOOL;
    bFaultReset_Prev: BOOL;
    
    // internal run memory
    bRunMemory      : BOOL;
    bFaultMemory    : BOOL;
    
    // ramp control
    rCurrentSpeed   : REAL  := 0.0;
    
    // timing للـ ramp (scan-based)
    rRampAccumulator: REAL  := 0.0;
    
    // fault delay
    tFaultDelay     : TON;
END_VAR

VAR_TEMP
    pData           : "UDT_PumpStatus";
    bPumpManual     : BOOL;     // الطلمبة دي في Manual
    bStart_Edge     : BOOL;
    bStop_Edge      : BOOL;
    bFaultReset_Edge: BOOL;
    bRunCmd         : BOOL;
    rTargetSpeed    : REAL;
    rStep           : REAL;
END_VAR

BEGIN
    // --------------------------------------------------------
    // اجلب بيانات الطلمبة
    // --------------------------------------------------------
    pData := "DB_PumpData".Pump[iPumpIndex];
    
    bPumpManual := pData.bManualSelector OR NOT bMasterAuto;
    
    // --------------------------------------------------------
    // Edge Detection للـ Buttons
    // --------------------------------------------------------
    bStart_Edge     := pData.bStartButton AND NOT bStart_Prev;
    bStop_Edge      := NOT pData.bStopButton AND NOT bStop_Prev;   // NC: فتح = Stop
    bFaultReset_Edge:= bFaultReset AND NOT bFaultReset_Prev;
    
    bStart_Prev     := pData.bStartButton;
    bStop_Prev      := NOT pData.bStopButton;
    bFaultReset_Prev:= bFaultReset;
    
    // --------------------------------------------------------
    // إدارة الـ Fault
    // --------------------------------------------------------
    // Overload = FALSE يعني Overload Trip
    // Status word bit 3 = fault في الـ ATV312
    
    IF (NOT pData.bOverload) OR ((pData.iStatusWord AND 16#0008) <> 0) THEN
        bFaultMemory := TRUE;
    END_IF;
    
    // Reset الفولت
    IF bFaultReset_Edge THEN
        IF pData.bOverload THEN     // لازم يتصلح الـ Overload الأول
            bFaultMemory := FALSE;
        END_IF;
    END_IF;
    
    // --------------------------------------------------------
    // منطق التشغيل - Manual
    // --------------------------------------------------------
    IF bPumpManual THEN
        IF bStart_Edge AND NOT bFaultMemory THEN
            bRunMemory := TRUE;
            "DB_PumpData".Pump[iPumpIndex].iStartCount := 
                "DB_PumpData".Pump[iPumpIndex].iStartCount + 1;
        END_IF;
        
        IF bStop_Edge OR bFaultMemory THEN
            bRunMemory := FALSE;
        END_IF;
        
        bRunCmd     := bRunMemory AND pData.bIsEnabled;
        rTargetSpeed:= rManualSpeed;
        
    // --------------------------------------------------------
    // منطق التشغيل - Automatic
    // --------------------------------------------------------
    ELSE
        // في الـ Auto: فولت = وقف فوري والـ Standby تدخل
        IF bFaultMemory THEN
            bRunMemory := FALSE;
        ELSIF bAutoRunCmd AND NOT bFaultMemory THEN
            bRunMemory := TRUE;
            "DB_PumpData".Pump[iPumpIndex].iStartCount := 
                "DB_PumpData".Pump[iPumpIndex].iStartCount + 1;
        ELSE
            bRunMemory := FALSE;
        END_IF;
        
        bRunCmd     := bRunMemory AND pData.bIsEnabled;
        rTargetSpeed:= rAutoSpeed;
    END_IF;
    
    // --------------------------------------------------------
    // Speed Ramp - السرعة بتزيد تدريجي مش هتش
    // --------------------------------------------------------
    IF bRunCmd THEN
        IF rCurrentSpeed < rTargetSpeed THEN
            rCurrentSpeed := rCurrentSpeed + rRampRate * 0.1;  // 100ms scan
            IF rCurrentSpeed > rTargetSpeed THEN
                rCurrentSpeed := rTargetSpeed;
            END_IF;
        ELSIF rCurrentSpeed > rTargetSpeed THEN
            rCurrentSpeed := rCurrentSpeed - rRampRate * 0.1;
            IF rCurrentSpeed < rTargetSpeed THEN
                rCurrentSpeed := rTargetSpeed;
            END_IF;
        END_IF;
    ELSE
        // وقفت → Speed ترجع لـ 0
        rCurrentSpeed := 0.0;
    END_IF;
    
    // --------------------------------------------------------
    // كتابة النتايج على DB_PumpData
    // --------------------------------------------------------
    "DB_PumpData".Pump[iPumpIndex].bRunCommand   := bRunCmd;
    "DB_PumpData".Pump[iPumpIndex].bIsRunning    := bRunCmd AND pData.bRunFeedback;
    "DB_PumpData".Pump[iPumpIndex].bIsFault      := bFaultMemory;
    "DB_PumpData".Pump[iPumpIndex].rCurrentRamp  := rCurrentSpeed;
    "DB_PumpData".Pump[iPumpIndex].bAutoMode     := NOT bPumpManual;
    
    // الـ Speed word للـ Modbus: Hz × 10 (50Hz → 500)
    // Max speed = 50Hz = 100%
    "DB_PumpData".Pump[iPumpIndex].iSpeedWord := 
        REAL_TO_INT(rCurrentSpeed / 100.0 * 500.0);
    
    // Control Word للـ ATV312
    IF bRunCmd THEN
        "DB_PumpData".Pump[iPumpIndex].iControlWord := 16#000F;  // RUN
    ELSIF bFaultReset_Edge THEN
        "DB_PumpData".Pump[iPumpIndex].iControlWord := 16#0080;  // Fault Reset
    ELSE
        "DB_PumpData".Pump[iPumpIndex].iControlWord := 16#0006;  // Stop
    END_IF;
    
    // Lamps
    "DB_PumpData".Pump[iPumpIndex].bRunLamp   := pData.bRunFeedback;
    "DB_PumpData".Pump[iPumpIndex].bFaultLamp := bFaultMemory;
    
    // Outputs
    bRunning     := bRunCmd AND pData.bRunFeedback;
    bFault       := bFaultMemory;
    rActualSpeed := rCurrentSpeed;
    
    // --------------------------------------------------------
    // Hour Counter - بيكمل مع Manual وAuto
    // --------------------------------------------------------
    IF bRunCmd THEN
        // كل Scan = 100ms = 100/3600000 ساعة
        "DB_PumpData".Pump[iPumpIndex].rRunningHours := 
            "DB_PumpData".Pump[iPumpIndex].rRunningHours + (0.1 / 3600.0);
            
        "DB_PumpData".Pump[iPumpIndex].rHoursSinceRotation := 
            "DB_PumpData".Pump[iPumpIndex].rHoursSinceRotation + (0.1 / 3600.0);
    END_IF;

END_FUNCTION_BLOCK
